# Copy to .env for local development. Never commit .env or backup files.
SECRET_KEY=change-me
DEBUG=True
# For docker-compose blue/green, add api-blue,api-green (Reflex -> API over internal DNS).
ALLOWED_HOSTS=localhost,127.0.0.1
# Optional: set LOG_FULL_USERNAME=1 only when debugging auth locally (logs raw usernames).
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
